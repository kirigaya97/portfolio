---
import { getCollection } from 'astro:content';
import type { Lang } from '../../i18n/ui';
import { useTranslations } from '../../i18n/utils';

import ContactCTA from '../ContactCTA.astro';
import Reveal from '../Reveal.astro';

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const projects = await getCollection(lang === 'es' ? 'proyectos' : 'work');
const projectCount = projects.length;

const eduKeys = [
	'about.education.item1',
	'about.education.item2',
	'about.education.item3',
	'about.education.item4',
] as const;

const skillKeys = [
	'about.skills.item1',
	'about.skills.item2',
	'about.skills.item3',
	'about.skills.item4',
	'about.skills.item5',
] as const;

/** Split "Role - Place (years)" into its parts. */
function parseEdu(value: string) {
	const paren = value.match(/\(([^)]*)\)\s*$/);
	const year = paren ? paren[1] : '';
	const head = (paren ? value.slice(0, paren.index) : value).trim();
	const dash = head.indexOf(' - ');
	return {
		year,
		role: dash === -1 ? head : head.slice(0, dash).trim(),
		place: dash === -1 ? '' : head.slice(dash + 3).trim(),
	};
}

/** Split "Label - comma, separated, values" into label + value. */
function parseSkill(value: string) {
	const dash = value.indexOf(' - ');
	return {
		label: dash === -1 ? value : value.slice(0, dash).trim(),
		value: dash === -1 ? '' : value.slice(dash + 3).trim(),
	};
}

const education = eduKeys.map((k) => parseEdu(t(k)));
const skills = skillKeys.map((k) => parseSkill(t(k)));

const stats = [
	{ value: '2020', label: t('about.stats.sinceLabel') },
	{ value: `${projectCount}`, label: t('about.stats.projectsLabel') },
	{ value: t('about.stats.locationValue'), label: t('about.stats.locationLabel') },
];
---

<div class="about">
	{/* ---------- Intro ----------
	   NOTE: styled elements are kept *literal* (inside <Reveal>, not as Reveal's
	   own root) so Astro's scoped styles apply. Reveal is a transparent wrapper. */}
	<header class="intro wrapper">
		<div class="intro-glow" aria-hidden="true"></div>
		<Reveal>
			<div class="intro-copy">
				<p class="kicker">{t('nav.about')}</p>
				<h1 class="intro-title">{t('about.hero.title')}</h1>
				<p class="intro-lead">{t('about.hero.tagline')}</p>
			</div>
		</Reveal>

		<Reveal delay={140}>
			<figure class="portrait">
				<div class="portrait-frame">
					<img
						src="/assets/pixelart.webp"
						width="508"
						height="191"
						alt="Rodrigo Camino — pixel-art self-portrait with his cat over a backdrop of code"
						loading="eager"
					/>
				</div>
				<figcaption class="portrait-cap kicker">
					<span class="dot" aria-hidden="true"></span>{t('about.portrait.caption')}
				</figcaption>
			</figure>
		</Reveal>
	</header>

	{/* ---------- Stats ---------- */}
	<Reveal>
		<section class="stats wrapper">
			{
				stats.map((s) => (
					<div class="stat">
						<span class="stat-value">{s.value}</span>
						<span class="stat-label kicker">{s.label}</span>
					</div>
				))
			}
		</section>
	</Reveal>

	{/* ---------- Background ---------- */}
	<section class="wrapper block">
		<div class="sec-head">
			<span class="sec-index kicker">01</span>
			<h2 class="sec-title">{t('about.background.heading')}</h2>
		</div>
		<Reveal>
			<div class="block-body">
				<p class="prose lead-prose">{t('about.background.p1')}</p>
				<p class="prose">{t('about.background.p2')}</p>
			</div>
		</Reveal>
	</section>

	{/* ---------- Trajectory / timeline ---------- */}
	<section class="wrapper block">
		<div class="sec-head">
			<span class="sec-index kicker">02</span>
			<h2 class="sec-title">{t('about.education.heading')}</h2>
		</div>
		<Reveal>
			<ol class="timeline">
				{
					education.map((e) => (
						<li class="t-item">
							<span class="t-year kicker">{e.year}</span>
							<div class="t-body">
								<h3 class="t-role">{e.role}</h3>
								{e.place && <p class="t-place">{e.place}</p>}
							</div>
						</li>
					))
				}
			</ol>
		</Reveal>
	</section>

	{/* ---------- Capabilities ---------- */}
	<section class="wrapper block">
		<div class="sec-head">
			<span class="sec-index kicker">03</span>
			<h2 class="sec-title">{t('about.skills.heading')}</h2>
		</div>
		<Reveal>
			<dl class="caps">
				{
					skills.map((s) => (
						<div class="cap">
							<dt class="cap-label kicker">{s.label}</dt>
							<dd class="cap-value">{s.value}</dd>
						</div>
					))
				}
			</dl>
		</Reveal>
	</section>

	<Reveal>
		<ContactCTA lang={lang} />
	</Reveal>
</div>

<style>
	.about {
		display: flex;
		flex-direction: column;
		gap: clamp(4rem, 3rem + 6vw, 8rem);
		padding-top: clamp(3rem, 2rem + 4vw, 6rem);
	}

	/* ---------- Intro ---------- */
	.intro {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: clamp(2.5rem, 1.8rem + 3vw, 4rem);
	}

	.intro-glow {
		position: absolute;
		inset: -8rem -20% auto -20%;
		height: 30rem;
		background: radial-gradient(50% 60% at 60% 0%, var(--accent-soft), transparent 70%);
		pointer-events: none;
		z-index: -1;
	}

	.intro-copy {
		display: flex;
		flex-direction: column;
		gap: 1.1rem;
		max-width: 30ch;
	}

	.intro-title {
		font-size: var(--text-display);
		line-height: 0.95;
		letter-spacing: -0.03em;
	}

	.intro-lead {
		font-size: var(--text-lg);
		line-height: 1.5;
		color: var(--text-dim);
		max-width: 42ch;
	}

	/* Pixel-art portrait — crisp upscaled, stage-lit frame */
	.portrait {
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.85rem;
	}

	.portrait-frame {
		position: relative;
		border: 1px solid var(--border-strong);
		border-radius: var(--radius);
		padding: 0.5rem;
		background: linear-gradient(180deg, var(--surface), var(--surface-2));
		box-shadow:
			var(--shadow-md),
			0 0 0 1px var(--accent-line),
			0 18px 60px -28px rgba(245, 165, 36, 0.5);
		overflow: hidden;
	}

	.portrait-frame::after {
		content: '';
		position: absolute;
		inset: 0;
		background-image: url('/assets/backgrounds/noise.png');
		background-size: 180px;
		opacity: 0.05;
		mix-blend-mode: overlay;
		pointer-events: none;
	}

	.portrait-frame img {
		width: 100%;
		height: auto;
		image-rendering: pixelated;
		border-radius: calc(var(--radius) - 0.35rem);
		display: block;
	}

	.portrait-cap {
		display: inline-flex;
		align-items: center;
		gap: 0.55rem;
		color: var(--text-dim);
	}
	.portrait-cap .dot {
		width: 0.45rem;
		height: 0.45rem;
		border-radius: 50%;
		background: var(--accent);
		box-shadow: 0 0 0 3px var(--accent-soft);
	}

	@media (min-width: 56em) {
		.intro {
			display: grid;
			grid-template-columns: 1fr 1fr;
			align-items: end;
			gap: clamp(2rem, 1rem + 4vw, 5rem);
		}
		.intro-copy {
			padding-bottom: 0.5rem;
		}
	}

	/* ---------- Stats ---------- */
	.stats {
		display: grid;
		grid-template-columns: 1fr;
		gap: 0;
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		background: var(--surface);
		overflow: hidden;
	}
	.stat {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		padding: clamp(1.5rem, 1.1rem + 1.4vw, 2.4rem);
		border-top: 1px solid var(--border);
	}
	.stat:first-child {
		border-top: none;
	}
	.stat-value {
		font-family: var(--font-display);
		font-size: var(--text-2xl);
		font-weight: 600;
		line-height: 1;
		letter-spacing: -0.02em;
		color: var(--text-strong);
		text-wrap: balance;
	}
	.stat-label {
		color: var(--text-dim);
	}

	@media (min-width: 44em) {
		.stats {
			grid-template-columns: repeat(3, 1fr);
		}
		.stat {
			border-top: none;
			border-left: 1px solid var(--border);
		}
		.stat:first-child {
			border-left: none;
		}
	}

	/* ---------- Section blocks ---------- */
	.block {
		display: flex;
		flex-direction: column;
		gap: clamp(1.75rem, 1.2rem + 2vw, 2.75rem);
	}

	.sec-head {
		display: flex;
		align-items: baseline;
		gap: 1rem;
		padding-bottom: 1.1rem;
		border-bottom: 1px solid var(--border);
	}
	.sec-index {
		color: var(--accent);
		flex-shrink: 0;
	}
	.sec-title {
		font-size: var(--text-xl);
	}

	.block-body {
		display: grid;
		gap: 1.5rem;
		max-width: var(--measure);
	}
	.prose {
		color: var(--text);
		line-height: 1.7;
	}
	.lead-prose {
		font-size: var(--text-md);
		color: var(--text-strong);
	}

	@media (min-width: 50em) {
		.block {
			display: grid;
			grid-template-columns: minmax(0, 14rem) 1fr;
			gap: 3rem;
			align-items: start;
		}
		.sec-head {
			flex-direction: column;
			gap: 0.6rem;
			border-bottom: none;
			padding-bottom: 0;
			position: sticky;
			top: 6rem;
		}
		.block-body {
			margin: 0;
		}
	}

	/* ---------- Timeline ---------- */
	.timeline {
		list-style: none;
		margin: 0;
		padding: 0;
		position: relative;
		padding-left: 1.85rem;
	}
	.timeline::before {
		content: '';
		position: absolute;
		left: 0.3rem;
		top: 0.6rem;
		bottom: 0.6rem;
		width: 1px;
		background: linear-gradient(var(--accent-line), var(--border) 65%);
	}
	.t-item {
		position: relative;
		padding-block: 1.5rem;
		border-top: 1px solid var(--border);
	}
	.t-item:first-child {
		border-top: none;
		padding-top: 0.2rem;
	}
	.t-item::before {
		content: '';
		position: absolute;
		left: calc(-1.85rem + 0.3rem);
		top: 1.95rem;
		width: 0.62rem;
		height: 0.62rem;
		border-radius: 50%;
		background: var(--accent);
		transform: translateX(-50%);
		box-shadow:
			0 0 0 4px var(--bg),
			0 0 0 5px var(--accent-line);
	}
	.t-item:first-child::before {
		top: 0.55rem;
	}
	.t-year {
		color: var(--accent);
		display: block;
		margin-bottom: 0.4rem;
	}
	.t-role {
		font-size: var(--text-md);
		font-weight: 600;
		letter-spacing: -0.01em;
		color: var(--text-strong);
	}
	.t-place {
		color: var(--text-dim);
		font-size: var(--text-sm);
		margin-top: 0.15rem;
	}

	@media (min-width: 38em) {
		.t-item {
			display: grid;
			grid-template-columns: 9rem 1fr;
			gap: 1.5rem;
			align-items: baseline;
		}
		.t-year {
			margin-bottom: 0;
			padding-top: 0.1rem;
		}
	}

	/* ---------- Capability matrix ---------- */
	.caps {
		margin: 0;
		display: flex;
		flex-direction: column;
	}
	.cap {
		display: grid;
		gap: 0.4rem;
		padding-block: 1.4rem;
		border-top: 1px solid var(--border);
	}
	.cap:first-child {
		border-top: none;
		padding-top: 0;
	}
	.cap-label {
		color: var(--accent);
		align-self: start;
		padding-top: 0.2rem;
	}
	.cap-value {
		margin: 0;
		color: var(--text);
		font-size: var(--text-md);
		line-height: 1.5;
	}

	@media (min-width: 44em) {
		.cap {
			grid-template-columns: 13rem 1fr;
			gap: 2.5rem;
		}
	}
</style>
