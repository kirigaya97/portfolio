---
import type { Lang } from '../i18n/ui';
import { languages, routes } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);

const otherLang: Lang = lang === 'en' ? 'es' : 'en';
const otherLangLabel = languages[otherLang];

/**
 * Compute the equivalent URL in the target language server-side,
 * using the route map to swap locale-specific slugs.
 *
 * Strategy:
 * - Strip the leading locale prefix (/es) from the current path to get the
 *   locale-neutral path segments.
 * - Replace any locale-specific slug (currently only work/proyectos) with the
 *   target-locale slug.
 * - Re-prefix for the target locale (EN = no prefix, ES = /es).
 */
const currentPath = Astro.url.pathname;

// Strip locale prefix to get a path that starts with /
let neutralPath = currentPath;
if (neutralPath.startsWith('/es')) {
  neutralPath = neutralPath.slice(3) || '/';
}
if (!neutralPath.startsWith('/')) neutralPath = '/' + neutralPath;

// Replace locale-specific slugs for routes that differ between locales.
// Currently only `work` differs: EN=/work, ES=/proyectos.
const slugMap: Record<string, string> = {};
for (const key of Object.keys(routes) as (keyof typeof routes)[]) {
  const fromSlug = routes[key][lang];
  const toSlug = routes[key][otherLang];
  if (fromSlug !== toSlug && fromSlug !== '') {
    slugMap[fromSlug] = toSlug;
  }
}

// Apply slug swaps: replace the first path segment if it matches.
const segments = neutralPath.split('/'); // ['', 'work', ...]
if (segments.length >= 2 && segments[1] in slugMap) {
  segments[1] = slugMap[segments[1]];
  neutralPath = segments.join('/') || '/';
}

// Build the target href with the correct locale prefix.
const targetHref = otherLang === 'en'
  ? (neutralPath || '/')
  : '/es' + (neutralPath === '/' ? '' : neutralPath);
---

<a href={targetHref} class="lang-toggle-link">
	<span class="sr-only">{t('lang.switch')}</span>
	{otherLangLabel}
</a>


<style>

	.lang-toggle-link {
		display: flex;
		border: 0;
		border-radius: 6px;
		padding: 5px;
		background-color: var(--accent-text-over);
		box-shadow: inset 0 0 0 1px var(--accent-overlay);
		cursor: pointer;
		text-decoration: none;
		color: inherit;
	}

	:global(.theme-dark) .lang-toggle-link {
		display: flex;
		border: 0;
		border-radius: 6px;
		padding: 5px;
		background-color: var(--accent-regular);
		box-shadow: inset 0 0 0 1px var(--accent-overlay);
		cursor: pointer;
	}

	:global(.theme-dark) .lang-toggle-link:hover {
		background-color: #ffffff;
		box-shadow: inset 0 0 0 1px var(--accent-overlay);
		color: var(--accent-regular);
	}

	.lang-toggle-link:hover {
		background-color: var(--accent-regular);
		box-shadow: inset 0 0 0 1px var(--accent-overlay);
		color: var(--accent-text-over);
	}


	.icon {
		z-index: 1;
		position: relative;
		display: flex;
		padding: 0.5rem;
		width: 2rem;
		height: 2rem;
		font-size: 1rem;
		color: var(--accent-overlay);
	}

	.icon.light::before {
		content: '';
		z-index: -1;
		position: absolute;
		inset: 0;
		background-color: var(--accent-regular);
		border-radius: 999rem;
	}

	:global(.theme-dark) .icon.light::before {
		transform: translateX(100%);
	}

	:global(.theme-dark) .icon.dark,
	:global(html:not(.theme-dark)) .icon.light,
	.lang-toggle-link[aria-pressed='false'] .icon.light {
		color: var(--accent-text-over);
	}

	@media (prefers-reduced-motion: no-preference) {
		.icon,
		.icon.light::before {
			transition:
				transform var(--theme-transition),
				color var(--theme-transition);
		}
	}

	@media (forced-colors: active) {
		.icon.light::before {
			background-color: SelectedItem;
		}
	}
</style>
